# PSL Chain Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# BLOCKCHAIN CONFIGURATION
# ============================================================================
NEXT_PUBLIC_WIREFLUID_CHAIN_ID=92533
NEXT_PUBLIC_WIREFLUID_RPC_URL=https://rpc.wirefluid.com
NEXT_PUBLIC_EXPLORER_URL=https://wirefluidscan.com

# ============================================================================
# CONTRACT ADDRESSES
# ============================================================================
# Run `npm run generate-env` after deploying contracts to get these values

NEXT_PUBLIC_PRIZE_POOL_ADDRESS=
NEXT_PUBLIC_STAKING_CONTRACT_ADDRESS=
NEXT_PUBLIC_ORACLE_ADDRESS=
NEXT_PUBLIC_CHAMPION_NFT_ADDRESS=
NEXT_PUBLIC_MARKET_CONTRACT_ADDRESS=
NEXT_PUBLIC_PLAYER_TOKEN_FACTORY_ADDRESS=

# Player tokens as JSON string (get from npm run generate-env)
NEXT_PUBLIC_PLAYER_TOKENS=

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project dashboard

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service key (NEVER expose to client, only for backend/listener)
SUPABASE_SERVICE_KEY=your_service_key_here

# ============================================================================
# WALLETCONNECT (Optional but recommended)
# ============================================================================
# Get a free project ID from https://cloud.walletconnect.com/

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ============================================================================
# DEVELOPMENT ONLY (Not needed for production)
# ============================================================================
# These are only needed if you're deploying contracts locally

WIREFLUID_RPC_URL=https://rpc.wirefluid.com
PRIVATE_KEY=your_private_key_for_deployment

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. NEVER commit .env or .env.local to git
# 2. Use NEXT_PUBLIC_ prefix for client-side variables only
# 3. Keep SUPABASE_SERVICE_KEY secret (backend only)
# 4. For Vercel deployment, add all NEXT_PUBLIC_* variables to Vercel dashboard
# 5. Run `npm run generate-env` to get contract addresses after deployment
#
